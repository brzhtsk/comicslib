generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  READER
  AUTHOR
  TRANSLATOR
}

enum ComicStatus {
  ONGOING
  COMPLETED
  HIATUS
}

enum CollectionType {
  READING
  COMPLETED
  PLANNED
  FAVOURITE
  CUSTOM
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique @db.VarChar(50)
  email       String   @unique @db.VarChar(255)
  password    String
  role        Role     @default(READER)
  avatarUrl   String?
  bio         String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publishedComics  Comic[]           @relation("PublisherComics")
  translatedComics Comic[]           @relation("TranslatorComics")
  collections      Collection[]
  comments         Comment[]
  commentReactions CommentReaction[]
  likes            Like[]
  views            ComicView[]

  @@map("users")
}

model Comic {
  id           Int         @id @default(autoincrement())
  title        String      @db.VarChar(255)
  description  String?     @db.Text
  coverUrl     String
  status       ComicStatus @default(ONGOING)
  authorName   String      @db.VarChar(255)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  publisherId  Int
  publisher    User        @relation("PublisherComics", fields: [publisherId], references: [id], onDelete: Cascade)

  translatorId Int?
  translator   User?       @relation("TranslatorComics", fields: [translatorId], references: [id], onDelete: SetNull)

  chapters    Chapter[]
  genres      ComicGenre[]
  tags        ComicTag[]
  collections CollectionItem[]
  comments    Comment[]
  likes       Like[]
  views       ComicView[]

  @@map("comics")
}

model Chapter {
  id        Int      @id @default(autoincrement())
  title     String?  @db.VarChar(255)
  number    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comicId   Int
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)

  pages    ChapterPage[]
  comments Comment[]
  likes    Like[]

  @@unique([comicId, number])
  @@map("chapters")
}

model ChapterPage {
  id        Int      @id @default(autoincrement())
  url       String
  order     Int
  createdAt DateTime @default(now())

  chapterId Int
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, order])
  @@map("chapter_pages")
}

model Genre {
  id     Int          @id @default(autoincrement())
  name   String       @unique @db.VarChar(100)
  comics ComicGenre[]

  @@map("genres")
}

model ComicGenre {
  comicId Int
  genreId Int
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([comicId, genreId])
  @@map("comic_genres")
}

model Tag {
  id     Int        @id @default(autoincrement())
  name   String     @unique @db.VarChar(100)
  comics ComicTag[]

  @@map("tags")
}

model ComicTag {
  comicId Int
  tagId   Int
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([comicId, tagId])
  @@map("comic_tags")
}

// Колекція: type=CUSTOM означає власну, решта — базові системні
model Collection {
  id        Int            @id @default(autoincrement())
  name      String         @db.VarChar(100)
  type      CollectionType @default(CUSTOM)
  createdAt DateTime       @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CollectionItem[]

  // Унікальність: один базовий тип на юзера АБО унікальна назва для CUSTOM
  @@unique([userId, type, name])
  @@map("collections")
}

// Виключна логіка: один комікс — одна колекція одного юзера
model CollectionItem {
  id      Int      @id @default(autoincrement())
  addedAt DateTime @default(now())

  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  comicId Int
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  userId Int

  @@unique([userId, comicId])
  @@map("collection_items")
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  comicId Int
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  chapterId Int?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  parentId Int?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  reactions CommentReaction[]

  @@map("comments")
}

model CommentReaction {
  id        Int          @id @default(autoincrement())
  type      ReactionType
  createdAt DateTime     @default(now())

  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("comment_reactions")
}

model Like {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  comicId Int
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  chapterId Int?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId, chapterId])
  @@map("likes")
}

model ComicView {
  id       Int      @id @default(autoincrement())
  viewedAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  comicId Int
  comic   Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId])
  @@map("comic_views")
}
